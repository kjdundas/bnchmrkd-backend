# Supabase PostgreSQL connection string
# Replace with your actual Supabase credentials
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase JWT secret — required for API authentication.
# Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# OpenAI API key for AI Scanner / Assistant
OPENAI_API_KEY=sk-your-key-here

# Comma-separated allowed CORS origins for production
ALLOWED_ORIGINS=https://bnchmrkd.app,https://bnchmrkd.com
